
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Evo Perfume - Login</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial;}

body{
  height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
  background:#eee;
}

.container{
  width:1050px;
  height:600px;
  display:flex;
  background:#fff;
  border-radius:15px;
  overflow:hidden;
  box-shadow:0 10px 30px rgba(0,0,0,0.2);
}

/* LEFT */
.left{
  width:50%;
  padding:40px;
  display:flex;
  flex-direction:column;
  justify-content:center;
}

.logo{
  margin-bottom:15px;
  letter-spacing:2px;
  font-family: "DM Serif Text", serif;
  font-weight: 600;
  font-weight: bold;
}

.left h1{
  font-size:37px;
  margin-bottom:5px;
  font-family: "DM Serif Text", serif;
  font-weight: 600;
  color: #e07878;
  text-shadow: 0 2px 8px rgba(184, 139, 139, 0.3);
}

.left p{font-size:13px;color:#777;margin-bottom:20px;}

label{font-size:13px;margin-top:10px; display: block;}

input[type="email"], input[type="password"], input[type="text"]{
  width:100%;
  padding:10px;
  border:1px solid #ccc;
  border-radius:6px;
  margin-top: 5px;
}

.password-box{position:relative;}

.eye{
  position:absolute;
  right:10px;
  top:15px;
  cursor:pointer;
}

.options{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-top:10px;
  font-size:12px;
}

.forgot{
  color:#007bff;
  text-decoration:underline;
  cursor:pointer;
}

button{
  padding:10px;
  margin-top:15px;
  border:none;
  border-radius:6px;
  cursor:pointer;
  width: 100%;
}

.login-btn{
  background: #e07878;
  color:#fff;
  font-family: "arial", sans-serif;
  font-weight: 600;
}

.signup{
  text-align:center;
  font-size:13px;
  margin-top:15px;
}

.signup a{
  color:#007bff;
  text-decoration:none;
}

.security{
  font-size:11px;
  color:#999;
  text-align:center;
  margin-top:15px;
}

/* RIGHT VIDEO */
.right{
  width:50%;
  position:relative;
}

.right video{
  width:100%;
  height:100%;
  object-fit:cover;
}

.overlay{
  position:absolute;
  top:0;left:0;
  width:100%;height:100%;
  background:rgba(0,0,0,0.3);
}

.text{
  position:absolute;
  bottom:20px;
  left:20px;
  color:#ffeaea;
}

.error-message {
  background: #ffebee;
  color: #c62828;
  padding: 10px;
  border-radius: 6px;
  margin-top: 10px;
  font-size: 12px;
  display: none;
}
</style>
</head>
<body>

<div class="container">

  <div class="left">
    <div class="logo">EVO PERFUME</div>

    <h1>Welcome Back</h1>
    <p>Login to your account</p>

    <div id="errorMsg" class="error-message"></div>

    <label>Email</label>
    <input type="email" id="email" placeholder="Enter your email" required>

    <label>Password</label>
    <div class="password-box">
      <input type="password" id="password" placeholder="******">
      <span class="eye" onclick="togglePass()">👁</span>
    </div>

    <div class="options">
      <label><input type="checkbox" id="rememberMe"> Remember me</label>
      <span class="forgot">Forgot Password?</span>
    </div>

    <button class="login-btn" onclick="handleLogin()">Login</button>

    <div class="signup">
      Not an Evo member? <a href="./register">Sign Up</a>
    </div>

    <div class="security">
      Your information is securely protected 🔒
    </div>

  </div>

  <div class="right">
    <video autoplay muted loop>
      <source src="https://res.cloudinary.com/dlwdvhcn2/video/upload/v1778258122/login-video_wrwcuk.mp4" type="video/mp4">
    </video>
    <div class="overlay"></div>

    <div class="text">
      <h3>Evo Perfume</h3>
      <p>Feel the luxury</p>
    </div>
  </div>

</div>

<script>
function togglePass(){
  let p = document.getElementById('password');
  let eye = document.querySelector('.eye');
  if(p.type === 'password'){
    p.type = 'text';
    eye.textContent = '🙈';
  } else {
    p.type = 'password';
    eye.textContent = '👁';
  }
}

async function handleLogin() {
  const email = document.getElementById('email').value.trim();
  const password = document.getElementById('password').value;
  const rememberMe = document.getElementById('rememberMe').checked;

  // Clear previous message
  document.getElementById('errorMsg').style.display = 'none';

  if (!email || !password) {
    showError('Please enter both email and password');
    return;
  }

  try {
    const response = await fetch('/api/login', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({ email, password })
    });

    const data = await response.json();

    if (data.success) {
      if (rememberMe) {
        // Session already handles this, but we can extend it
        console.log('Remember me enabled');
      }
      window.location.href = data.redirect;
    } else {
      showError(data.message);
    }
  } catch (error) {
    showError('Connection error. Please try again.');
  }
}

function showError(message) {
  const errorDiv = document.getElementById('errorMsg');
  errorDiv.textContent = message;
  errorDiv.style.display = 'block';
  setTimeout(() => {
    errorDiv.style.display = 'none';
  }, 3000);
}
</script>

</body>
</html>