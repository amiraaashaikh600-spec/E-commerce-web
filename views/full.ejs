<script>
// Additional inline script for immediate fixes
(function() {
    // Fix for any missing elements
    const cartCount = document.getElementById('cartCount');
    if (cartCount && !cartCount.style.display) {
        cartCount.style.display = 'none';
    }
    
    // Ensure logout button shows for logged-in users
    fetch('/api/user', { credentials: 'include' })
        .then(res => res.json())
        .then(data => {
            if (data.success && data.user) {
                const userNameDisplay = document.getElementById('userNameDisplay');
                if (userNameDisplay) {
                    userNameDisplay.textContent = `Welcome, ${data.user.fullName.split(' ')[0]}`;
                }
            }
        })
        .catch(err => console.error('Error:', err));
})();
</script>
